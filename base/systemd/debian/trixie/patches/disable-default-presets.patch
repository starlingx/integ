From 6e2fd25cf413aa35980d9e2097bb922b072815de Mon Sep 17 00:00:00 2001
From: Sai Lakshmi Teja Vanka <SaiLakshmiTeja.Vanka@windriver.com>
Date: Tue, 27 Jan 2026 01:36:48 -0500
Subject: [PATCH] disable default presets

Disable the following services:

- systemd-timesyncd
- systemd-networkd
- systemd-network-generator
- sysstemd-resolved
- systemd-homed
- systemd-userdbd
- systemd-boot-update
- systemd-confext
- systemd-journald-audit
- systemd-homed-activate
- systemd-mountfsd
- systemd-network-generator
Signed-off-by: Sai Lakshmi Teja Vanka <SaiLakshmiTeja.Vanka@windriver.com>
---
 presets/90-systemd.preset | 31 ++++++++++++++++---------------
 1 file changed, 16 insertions(+), 15 deletions(-)

diff --git a/presets/90-systemd.preset b/presets/90-systemd.preset
index da6b980..eca05d1 100644
--- a/presets/90-systemd.preset
+++ b/presets/90-systemd.preset
@@ -16,22 +16,23 @@ enable remote-cryptsetup.target
 enable machines.target
 
 enable getty@.service
-
-enable systemd-boot-update.service
-enable systemd-confext.service
-enable systemd-homed.service
-enable systemd-homed-activate.service
-enable systemd-journald-audit.socket
-enable systemd-mountfsd.socket
-enable systemd-network-generator.service
-enable systemd-networkd.service
-enable systemd-networkd-wait-online.service
-enable systemd-nsresourced.socket
 enable systemd-pstore.service
-enable systemd-resolved.service
-enable systemd-sysext.service
-enable systemd-timesyncd.service
-enable systemd-userdbd.socket
+
+disable systemd-boot-update.service
+disable systemd-confext.service
+disable systemd-homed.service
+disable systemd-homed-activate.service
+disable systemd-journald-audit.socket
+disable systemd-mountfsd.socket
+disable systemd-network-generator.service
+disable systemd-networkd.service
+disable systemd-networkd-wait-online.service
+disable systemd-nsresourced.socket
+
+disable systemd-resolved.service
+disable systemd-sysext.service
+disable systemd-timesyncd.service
+disable systemd-userdbd.socket
 
 disable console-getty.service
 disable debug-shell.service
-- 
2.43.0

