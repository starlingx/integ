From c7c472bdbe40d5477d36651c0c66d85674ad4f00 Mon Sep 17 00:00:00 2001
From: Vincent Cheng <vincent.cheng.xh@renesas.com>
Date: Sat, 19 Mar 2022 22:11:45 -0400
Subject: [PATCH] unicast: Add support to send CANCEL_UNICAST_TRANSMISSION
 TLVs.

Signed-off-by: Vincent Cheng <vincent.cheng.xh@renesas.com>
Reviewed-by: Jacob Keller <jacob.e.keller@intel.com>
Signed-off-by: Cole Walker <cole.walker@windriver.com>
(cherry picked from commit 868c5ee572114ffd667fdf5c981c85b02417f696)
---
 unicast_client.c | 72 ++++++++++++++++++++++++++++++++++++++++++++++--
 unicast_client.h | 19 +++++++++++++
 2 files changed, 89 insertions(+), 2 deletions(-)

diff --git a/unicast_client.c b/unicast_client.c
index f1a9d89..2a91744 100644
--- a/unicast_client.c
+++ b/unicast_client.c
@@ -64,6 +64,23 @@ static int attach_request(struct ptp_message *msg, int log_period,
 	return 0;
 }
 
+static int attach_cancel(struct ptp_message *msg, uint8_t message_type)
+{
+	struct cancel_unicast_xmit_tlv *req;
+	struct tlv_extra *extra;
+
+	extra = msg_tlv_append(msg, sizeof(*req));
+	if (!extra) {
+		return -1;
+	}
+	req = (struct cancel_unicast_xmit_tlv *) extra->tlv;
+	req->type = TLV_CANCEL_UNICAST_TRANSMISSION;
+	req->length = sizeof(*req) - sizeof(req->type) - sizeof(req->length);
+	req->message_type_flags = message_type << 4;
+
+	return 0;
+}
+
 static int unicast_client_announce(struct port *p,
 				   struct unicast_master_address *dst)
 {
@@ -327,7 +344,7 @@ int unicast_client_cancel(struct port *p, struct ptp_message *m,
 	}
 
 	pr_warning("%s: server unilaterally canceled unicast %s grant",
-		   p->log_name, msg_type_string(mtype));
+		   p->name, msg_type_string(mtype));
 
 	ucma->state = unicast_fsm(ucma->state, UC_EV_CANCEL);
 	ucma->granted &= ~(1 << mtype);
@@ -547,7 +564,7 @@ void unicast_client_state_changed(struct port *p)
 			ucma->state = unicast_fsm(ucma->state, UC_EV_UNSELECTED);
 
 			if ((prev_state != ucma->state) && (prev_state == UC_HAVE_SYDY)) {
-				unicast_client_tx_cancel(p, ucma, UNICAST_CANCEL_SYDY);
+				unicast_client_tx_cancel(p, ucma);
 			}
 			if (old_state != ucma->state) {
 				pr_info("port %d: [UC_FSM] Master %s UNSELECTED: %d->%d",
@@ -595,3 +612,54 @@ int unicast_client_timer(struct port *p)
 	unicast_client_set_tmo(p);
 	return err;
 }
+
+int unicast_client_msg_is_from_master_table_entry(struct port *p, struct ptp_message *m)
+{
+	struct unicast_master_address *ucma;
+	int found = 0;
+
+	if (!unicast_client_enabled(p)) {
+		return found;
+	}
+	STAILQ_FOREACH(ucma, &p->unicast_master_table->addrs, list) {
+		if (addreq(transport_type(p->trp), &ucma->address, &m->address)) {
+			found = 1;
+			break;
+		}
+	}
+	return found;
+}
+
+int unicast_client_tx_cancel(struct port *p,
+			     struct unicast_master_address *dst)
+{
+	struct ptp_message *msg;
+	int err;
+
+	msg = port_signaling_uc_construct(p, &dst->address, &dst->portIdentity);
+	if (!msg) {
+		return -1;
+	}
+	err = attach_cancel(msg, ANNOUNCE);
+	if (err) {
+		goto out;
+	}
+	err = attach_cancel(msg, SYNC);
+	if (err) {
+		goto out;
+	}
+	if (p->delayMechanism != DM_P2P) {
+		err = attach_cancel(msg, DELAY_RESP);
+		if (err) {
+			goto out;
+		}
+	}
+
+	err = port_prepare_and_send(p, msg, TRANS_GENERAL);
+	if (err) {
+		pr_err("%s: signaling message failed", p->name);
+	}
+out:
+	msg_put(msg);
+	return err;
+}
diff --git a/unicast_client.h b/unicast_client.h
index 16e291f..18a12c8 100644
--- a/unicast_client.h
+++ b/unicast_client.h
@@ -82,4 +82,23 @@ void unicast_client_state_changed(struct port *p);
  */
 int unicast_client_timer(struct port *p);
 
+/**
+ * Check whether a message was received from an entry in the unicast
+ * master table.
+ * @param p      The port in question.
+ * @param m      The message in question.
+ * @return       One (1) if the message is from an entry in the unicast
+ *               master table, or zero otherwise.
+ */
+int unicast_client_msg_is_from_master_table_entry(struct port *p, 
+						  struct ptp_message *m);
+
+/**
+ * Transmit CANCEL_UNICAST_TRANSMISSION TLV to destination address.
+ * @param p      The port in question.
+ * @param dst    The destination address.
+ * @return       Zero on success, non-zero otherwise.
+ */
+int unicast_client_tx_cancel(struct port *p,
+			     struct unicast_master_address *dst);
 #endif
-- 
