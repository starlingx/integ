From ea869d5414b649c6621f719b8c74a5001800d976 Mon Sep 17 00:00:00 2001
From: Cole Walker <cole.walker@windriver.com>
Date: Fri, 30 Jan 2026 18:45:22 -0500
Subject: [PATCH] Arm service timer when extending unicast contracts

Problem:
When a unicast client (BC) reboots and re-requests service from a GM,
the GM's unicast service timer fails to re-arm when extending existing
contracts. This causes the GM to stop sending unicast ANNOUNCE/SYNC
messages, breaking synchronization and preventing recovery.

Root Cause:
In unicast_service_add(), when a client re-requests an existing contract
(same message type, same interval), the code extends the contract duration
but does not call unicast_service_rearm_timer(). Without re-arming, the
timer remains disarmed and no unicast messages are transmitted.

Solution:
Add unicast_service_rearm_timer(p) call when extending existing contracts.
The function is idempotent and safe to call multiple times.

Logging Changes:
Add targeted debug logging for unicast negotiation troubleshooting:
- FSM state transitions (pr_info) - 6 logs for critical state changes
- Request/grant messages (pr_debug) - detailed protocol tracing
- ANNOUNCE TX/RX (pr_debug) - message flow tracking
- Error conditions (pr_warning) - invalid requests/grants

All routine operational logs use pr_debug to avoid production log noise.
Only significant FSM state changes use pr_info for visibility.

Impact:
- Fixes GM restart recovery in telecom profiles (ITU-T G.8275.x)
- Fixes BC restart recovery when using unicast negotiation
- No configuration changes required
- Minimal performance impact (called only during infrequent negotiations)

Testing:
Verified with GM restart and BC restart scenarios. Unicast service
successfully re-establishes after both types of restarts.

Signed-off-by: Cole Walker <cole.walker@windriver.com>
---
 port.c            | 10 ++++++++++
 port_signaling.c  |  3 +++
 unicast_client.c  | 41 +++++++++++++++++++++++++++++++++--------
 unicast_service.c | 13 ++++++++-----
 4 files changed, 54 insertions(+), 13 deletions(-)

diff --git a/port.c b/port.c
index b0e4ef8..94c946a 100644
--- a/port.c
+++ b/port.c
@@ -1495,6 +1495,9 @@ int port_tx_announce(struct port *p, struct address *dst)
 	err = port_prepare_and_send(p, msg, TRANS_GENERAL);
 	if (err) {
 		pr_err("port %hu: send announce failed", portnum(p));
+	} else if (dst) {
+		pr_debug("port %d: [ANNOUNCE_TX] Sent unicast ANNOUNCE to dst, seqId=%d",
+			 portnum(p), msg->header.sequenceId);
 	}
 	msg_put(msg);
 	return err;
@@ -1868,7 +1871,14 @@ int process_announce(struct port *p, struct ptp_message *m)
 {
 	int result = 0;
 
+	pr_debug("port %d: [ANNOUNCE_RX] Received ANNOUNCE from %s, stepsRemoved=%d, port_state=%d",
+		 portnum(p), pid2str(&m->header.sourcePortIdentity),
+		 m->announce.stepsRemoved, p->state);
+
 	if (m->announce.stepsRemoved >= clock_max_steps_removed(p->clock)) {
+		pr_warning("port %d: [ANNOUNCE_RX] Rejected: stepsRemoved %d >= max %d",
+			   portnum(p), m->announce.stepsRemoved,
+			   clock_max_steps_removed(p->clock));
 		return result;
 	}
 
diff --git a/port_signaling.c b/port_signaling.c
index 2f5a682..701b539 100644
--- a/port_signaling.c
+++ b/port_signaling.c
@@ -139,9 +139,12 @@ int process_signaling(struct port *p, struct ptp_message *m)
 				err = unicast_service_grant(p, m, extra);
 				break;
 			case SERVICE_DENIED:
+				pr_warning("port %d: [SIGNALING] Denying request", portnum(p));
 				err = unicast_service_deny(p, m, extra);
 				break;
 			case SERVICE_DISABLED:
+				pr_debug("port %d: [SIGNALING] Service disabled", portnum(p));
+				break;
 			default:
 				break;
 			}
diff --git a/unicast_client.c b/unicast_client.c
index 2f8640f..b846356 100644
--- a/unicast_client.c
+++ b/unicast_client.c
@@ -70,6 +70,9 @@ static int unicast_client_announce(struct port *p,
 	struct ptp_message *msg;
 	int err;
 
+	pr_debug("port %d: [UC_REQ] Sending ANNOUNCE request to %s, duration=%d",
+		  portnum(p), pid2str(&dst->portIdentity), p->unicast_req_duration);
+
 	msg = port_signaling_uc_construct(p, &dst->address, &dst->portIdentity);
 	if (!msg) {
 		return -1;
@@ -227,6 +230,9 @@ static int unicast_client_sydy(struct port *p,
 	struct ptp_message *msg;
 	int err;
 
+	pr_debug("port %d: [UC_REQ] Sending SYNC+DELAY_RESP request to %s",
+		  portnum(p), pid2str(&dst->portIdentity));
+
 	msg = port_signaling_uc_construct(p, &dst->address, &dst->portIdentity);
 	if (!msg) {
 		return -1;
@@ -414,11 +420,16 @@ void unicast_client_grant(struct port *p, struct ptp_message *m,
 
 	ucma = unicast_client_ok(p, m);
 	if (!ucma) {
+		pr_warning("port %d: [UC_GRANT] Received grant from unknown master", portnum(p));
 		return;
 	}
 	g = (struct grant_unicast_xmit_tlv *) extra->tlv;
 	mtype = g->message_type >> 4;
 
+	pr_debug("port %d: [UC_GRANT] Received %s grant from %s, duration=%u, state=%d, granted=0x%x",
+		  portnum(p), msg_type_string(mtype), pid2str(&m->header.sourcePortIdentity),
+		  g->durationField, ucma->state, ucma->granted);
+
 	if (!g->durationField) {
 		pr_warning("port %d: unicast grant of %s rejected",
 			   portnum(p), msg_type_string(mtype));
@@ -453,12 +464,17 @@ void unicast_client_grant(struct port *p, struct ptp_message *m,
 	case UC_WAIT:
 		if (mtype == ANNOUNCE) {
 			int was_unknown;
+			enum unicast_state old_state = ucma->state;
 			was_unknown = ucma->portIdentity.portNumber == 0xFFFF;
 			ucma->state = unicast_fsm(ucma->state, UC_EV_GRANT_ANN);
+			pr_info("port %d: [UC_FSM] WAIT->HAVE_ANN (old=%d, new=%d)",
+				 portnum(p), old_state, ucma->state);
 			ucma->portIdentity = m->header.sourcePortIdentity;
 			unicast_client_set_renewal(p, ucma, g->durationField);
 			/* Trigger state change now that we have port identity */
 			if (was_unknown) {
+				pr_info("port %d: [UC_FSM] Triggering state_changed after learning port identity",
+					 portnum(p));
 				unicast_client_state_changed(p);
 			}
 		}
@@ -469,16 +485,22 @@ void unicast_client_grant(struct port *p, struct ptp_message *m,
 		switch (mtype) {
 		case DELAY_RESP:
 			if ((ucma->granted & ucma->sydymsk) == ucma->sydymsk) {
+				enum unicast_state old_state = ucma->state;
 				ucma->state = unicast_fsm(ucma->state,
 							  UC_EV_GRANT_SYDY);
+				pr_info("port %d: [UC_FSM] NEED_SYDY->HAVE_SYDY via DELAY_RESP (old=%d, new=%d)",
+					 portnum(p), old_state, ucma->state);
 			}
 			unicast_client_set_renewal(p, ucma, g->durationField);
 			p->logMinDelayReqInterval = g->logInterMessagePeriod;
 			break;
 		case SYNC:
 			if ((ucma->granted & ucma->sydymsk) == ucma->sydymsk) {
+				enum unicast_state old_state = ucma->state;
 				ucma->state = unicast_fsm(ucma->state,
 							  UC_EV_GRANT_SYDY);
+				pr_info("port %d: [UC_FSM] NEED_SYDY->HAVE_SYDY via SYNC (old=%d, new=%d)",
+					 portnum(p), old_state, ucma->state);
 			}
 			unicast_client_set_renewal(p, ucma, g->durationField);
 			clock_sync_interval(p->clock, g->logInterMessagePeriod);
@@ -512,19 +534,23 @@ void unicast_client_state_changed(struct port *p)
 		return;
 	}
 	
-	pr_debug("port %d: unicast_client_state_changed called", portnum(p));
 	pid = clock_parent_identity(p->clock);
 
 	STAILQ_FOREACH(ucma, &p->unicast_master_table->addrs, list) {
+		enum unicast_state old_state = ucma->state;
 		if (pid_eq(&ucma->portIdentity, &pid)) {
 			ucma->state = unicast_fsm(ucma->state, UC_EV_SELECTED);
+			pr_info("port %d: [UC_FSM] Master %s SELECTED: %d->%d, granted=0x%x",
+				 portnum(p), pid2str(&ucma->portIdentity),
+				 old_state, ucma->state, ucma->granted);
 		} else {
 			ucma->state = unicast_fsm(ucma->state, UC_EV_UNSELECTED);
+			if (old_state != ucma->state) {
+				pr_info("port %d: [UC_FSM] Master %s UNSELECTED: %d->%d",
+					 portnum(p), pid2str(&ucma->portIdentity),
+					 old_state, ucma->state);
+			}
 		}
-		pr_debug("port %d: master %s state=%d granted=0x%x selected=%d",
-			portnum(p), pid2str(&ucma->portIdentity),
-			ucma->state, ucma->granted,
-			pid_eq(&ucma->portIdentity, &pid));
 	}
 }
 
@@ -533,13 +559,12 @@ int unicast_client_timer(struct port *p)
 	struct unicast_master_address *master;
 	int err = 0;
 
+	pr_debug("port %d: [UC_TIMER] Unicast client timer fired", portnum(p));
+
 	STAILQ_FOREACH(master, &p->unicast_master_table->addrs, list) {
 		if (master->type != transport_type(p->trp)) {
 			continue;
 		}
-		pr_debug("port %d: timer fired for master %s state=%d granted=0x%x",
-			portnum(p), pid2str(&master->portIdentity),
-			master->state, master->granted);
 		switch (master->state) {
 		case UC_WAIT:
 			err = unicast_client_announce(p, master);
diff --git a/unicast_service.c b/unicast_service.c
index d42c549..9c88873 100644
--- a/unicast_service.c
+++ b/unicast_service.c
@@ -286,6 +286,7 @@ int unicast_service_add(struct port *p, struct ptp_message *m,
 	case PDELAY_RESP:
 		return SERVICE_GRANTED;
 	default:
+		pr_warning("port %d: [UC_SRV] Denying unsupported message type", portnum(p));
 		return SERVICE_DENIED;
 	}
 
@@ -308,6 +309,8 @@ int unicast_service_add(struct port *p, struct ptp_message *m,
 				if (ctmp->message_types & mask) {
 					/* Contract is unchanged. */
 					unicast_service_extend(ctmp, req);
+					/* Ensure timer is armed */
+					unicast_service_rearm_timer(p);
 					return SERVICE_GRANTED;
 				}
 				/* This is the one to use. */
@@ -399,8 +402,11 @@ int unicast_service_grant(struct port *p, struct ptp_message *m,
 int unicast_service_initialize(struct port *p)
 {
 	struct config *cfg = clock_config(p->clock);
+	int unicast_listen;
 
-	if (!config_get_int(cfg, p->name, "unicast_listen")) {
+	unicast_listen = config_get_int(cfg, p->name, "unicast_listen");
+
+	if (!unicast_listen) {
 		return 0;
 	}
 	if (config_set_section_int(cfg, p->name, "hybrid_e2e", 1)) {
@@ -419,7 +425,6 @@ int unicast_service_initialize(struct port *p)
 	}
 	p->inhibit_multicast_service =
 		config_get_int(cfg, p->name, "inhibit_multicast_service");
-
 	return 0;
 }
 
@@ -499,10 +504,8 @@ int unicast_service_timer(struct port *p)
 
 	while ((interval = pqueue_peek(p->unicast_service->queue)) != NULL) {
 
-		pr_debug("peek i={2^%d} tmo={%lld,%ld}", interval->log_period,
-			 (long long)interval->tmo.tv_sec, interval->tmo.tv_nsec);
-
 		if (timespec_compare(&now, &interval->tmo) > 0) {
+			pr_debug("port %d: [UC_SRV_TIMER] Not yet time to send", portnum(p));
 			break;
 		}
 		interval = pqueue_extract(p->unicast_service->queue);
