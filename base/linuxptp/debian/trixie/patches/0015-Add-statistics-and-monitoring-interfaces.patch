--- /dev/null
+++ b/mon_socket.h
@@ -0,0 +1,60 @@
+/**
+ * @file mon_socket.h
+ * @brief Monitoring socket interface for statistics reporting.
+ * @note Copyright (C) 2026 Wind River Systems, Inc.
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 2 of the License, or
+ * (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+ * GNU General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License along
+ * with this program; if not, write to the Free Software Foundation, Inc.,
+ * 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA.
+ */
+#ifndef HAVE_MON_SOCKET_H
+#define HAVE_MON_SOCKET_H
+
+#define MON_SCK_BUFFER_SIZE 4096
+
+/**
+ * Open a monitoring socket.
+ * @param path  Configured path, or NULL to auto-derive from config_file.
+ * @param config_file  Config file path used to derive socket name.
+ * @param prefix  Daemon prefix for auto-derived path (e.g. "phc2sys", "ts2phc").
+ * @param fd_out  Pointer to store the listening socket fd.
+ * @param path_out  Pointer to store the heap-allocated socket path.
+ * @return Zero on success, -1 on error.
+ */
+int mon_socket_open(const char *path, const char *config_file,
+		    const char *prefix, int *fd_out, char **path_out);
+
+/**
+ * Accept a pending client and read its request.
+ * @param fd  The listening socket fd.
+ * @param buf  Buffer to store the received message.
+ * @param buflen  Size of the buffer.
+ * @return The client fd on success, -1 if no client or error.
+ */
+int mon_socket_accept(int fd, char *buf, size_t buflen);
+
+/**
+ * Send a response and close the client connection.
+ * @param client_fd  The client socket fd.
+ * @param resp  The response string to send.
+ */
+void mon_socket_reply(int client_fd, const char *resp);
+
+/**
+ * Close a monitoring socket and remove its path.
+ * @param fd  Pointer to the socket fd (set to -1 on return).
+ * @param path  Pointer to the path string (freed and set to NULL on return).
+ */
+void mon_socket_close(int *fd, char **path);
+
+#endif
diff --git a/phc2sys.8 b/phc2sys.8
index df0608a..a9229dc 100644
--- a/phc2sys.8
+++ b/phc2sys.8
@@ -331,6 +331,15 @@ Same as option
 .B \-t
 (see above).
 
+.TP
+.B mon_socket_path
+Path for the monitoring Unix domain socket used by external tools (e.g.,
+ptp-metrics-exporter) to query synchronization statistics via JSON.
+If empty (the default), the path is derived from the configuration filename
+as /var/run/phc2sys-mon-\fI<instance>\fP.
+If set to "disabled", the monitoring socket is not created.
+The default is "".
+
 .TP
 .B ntpshm_segment
 The number of the SHM segment used by ntpshm servo.  The default is 0.
