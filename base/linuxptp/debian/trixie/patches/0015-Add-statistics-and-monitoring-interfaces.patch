+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+ * GNU General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License along
+ * with this program; if not, write to the Free Software Foundation, Inc.,
+ * 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA.
+ */
+#include <errno.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/socket.h>
+#include <sys/stat.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+#include "mon_socket.h"
+#include "print.h"
+
+#define MON_SCK_PATH_LEN 108
+#define MON_SCK_FILEMODE (S_IRUSR|S_IWUSR|S_IRGRP|S_IWGRP|S_IROTH|S_IWOTH)
+
+int mon_socket_open(const char *path, const char *config_file,
+		    const char *prefix, int *fd_out, char **path_out)
+{
+	/* Sentinel to disable monitoring socket entirely */
+	if (path && strcmp(path, "disabled") == 0) {
+		*fd_out = -1;
+		*path_out = NULL;
+		pr_info("mon_socket: disabled by configuration");
+		return 0;
+	}
+
+	int fd, err;
+	struct sockaddr_un sa;
+	char *path_buf;
+	int prefix_len;
+
+	path_buf = malloc(MON_SCK_PATH_LEN);
+	if (!path_buf) {
+		pr_err("mon_socket: failed to allocate path buffer");
+		return -1;
+	}
+
+	if (!path || path[0] == '\0') {
+		if (!config_file) {
+			snprintf(path_buf, MON_SCK_PATH_LEN,
+				 "/var/run/%s-mon-default", prefix);
+		} else {
+			const char *base = strrchr(config_file, '/');
+
+			base = base ? base + 1 : config_file;
+			prefix_len = strlen(prefix);
+
+			if (strncmp(base, prefix, prefix_len) == 0 &&
+			    base[prefix_len] == '-') {
+				const char *inst = base + prefix_len + 1;
+				char *dot = strstr(inst, ".conf");
+				int len = dot ? (int)(dot - inst)
+					      : (int)strlen(inst);
+
+				snprintf(path_buf, MON_SCK_PATH_LEN,
+					 "/var/run/%s-mon-%.*s",
+					 prefix, len, inst);
+			} else {
+				snprintf(path_buf, MON_SCK_PATH_LEN,
+					 "/var/run/%s-mon-default", prefix);
+			}
+		}
+	} else {
+		strncpy(path_buf, path, MON_SCK_PATH_LEN - 1);
+		path_buf[MON_SCK_PATH_LEN - 1] = '\0';
+	}
+
+	unlink(path_buf);
+
+	fd = socket(AF_LOCAL, SOCK_STREAM | SOCK_NONBLOCK, 0);
+	if (fd < 0) {
+		pr_err("mon_socket: socket failed: %m");
+		free(path_buf);
+		return -1;
+	}
+
+	memset(&sa, 0, sizeof(sa));
+	sa.sun_family = AF_LOCAL;
+	strncpy(sa.sun_path, path_buf, sizeof(sa.sun_path) - 1);
+
+	err = bind(fd, (struct sockaddr *)&sa, sizeof(sa));
+	if (err < 0) {
+		pr_err("mon_socket: bind(%s) failed: %m", path_buf);
+		close(fd);
+		free(path_buf);
+		return -1;
+	}
+
+	err = listen(fd, 5);
+	if (err < 0) {
+		pr_err("mon_socket: listen failed: %m");
+		close(fd);
+		free(path_buf);
+		return -1;
+	}
+
+	chmod(path_buf, MON_SCK_FILEMODE);
+	pr_info("mon_socket: listening on %s", path_buf);
+
+	*fd_out = fd;
+	*path_out = path_buf;
+
+	return 0;
+}
+
+int mon_socket_accept(int fd, char *buf, size_t buflen)
+{
+	int client_fd;
+	ssize_t n;
+
+	if (fd < 0)
+		return -1;
+
+	client_fd = accept(fd, NULL, NULL);
+	if (client_fd < 0)
+		return -1;
+
+	n = recv(client_fd, buf, buflen - 1, MSG_DONTWAIT);
+	if (n <= 0) {
+		close(client_fd);
+		return -1;
+	}
+	buf[n] = '\0';
+
+	return client_fd;
+}
+
+void mon_socket_reply(int client_fd, const char *resp)
+{
+	send(client_fd, resp, strlen(resp), MSG_NOSIGNAL);
+	close(client_fd);
+}
+
+void mon_socket_close(int *fd, char **path)
+{
+	if (*fd >= 0) {
+		close(*fd);
+		*fd = -1;
+	}
+	if (*path) {
+		unlink(*path);
+		free(*path);
+		*path = NULL;
+	}
+}
