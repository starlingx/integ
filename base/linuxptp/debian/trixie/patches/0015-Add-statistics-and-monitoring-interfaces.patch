+static const char *ts2phc_servo_state_str(enum servo_state s)
+{
+	switch (s) {
+	case SERVO_UNLOCKED:
+		return "UNLOCKED";
+	case SERVO_JUMP:
+		return "JUMP";
+	case SERVO_LOCKED:
+		return "LOCKED";
+	case SERVO_LOCKED_STABLE:
+		return "LOCKED_STABLE";
+	default:
+		return "UNKNOWN";
+	}
