+
+static void ts2phc_mon_handle(struct ts2phc_private *priv)
+{
+	int client_fd, off, first;
+	char buf[MON_SCK_BUFFER_SIZE];
+	char resp[MON_SCK_BUFFER_SIZE];
+	struct ts2phc_clock *c;
+
+	client_fd = mon_socket_accept(priv->mon.fd, buf, sizeof(buf));
+	if (client_fd < 0)
+		return;
+
+	if (!strstr(buf, "\"command\"") || !strstr(buf, "\"stats\"")) {
+		snprintf(resp, sizeof(resp),
+			 "{\"error\":\"unknown command\"}");
+		mon_socket_reply(client_fd, resp);
+		return;
+	}
+
+	off = snprintf(resp, sizeof(resp),
+		       "{\"version\":1,\"clocks\":[");
+	first = 1;
+
+	LIST_FOREACH(c, &priv->clocks, list) {
+		char entry[256];
+		int elen;
+
+		if (!c->is_target || !c->mon_valid)
+			continue;
+
+		elen = snprintf(entry, sizeof(entry),
+				"%s{"
+				"\"offset\":%" PRId64 ","
+				"\"delay\":-1,"
+				"\"servo_state\":\"%s\","
+				"\"clock_source\":\"%s\""
+				"}",
+				first ? "" : ",",
+				c->mon_offset,
+				ts2phc_servo_state_str(c->servo_state),
+				c->name ? c->name : "unknown");
+
+		if (off + elen >= (int)sizeof(resp) - 32) {
+			off += snprintf(resp + off, sizeof(resp) - off,
+					"],\"truncated\":true}");
+			goto send_response;
+		}
+		memcpy(resp + off, entry, elen);
+		off += elen;
+		first = 0;
+	}
+
+	off += snprintf(resp + off, sizeof(resp) - off, "]}");
+
+	if (first) {
+		snprintf(resp, sizeof(resp),
+			 "{\"error\":\"no servo data\"}");
+	}
+
+send_response:
+	mon_socket_reply(client_fd, resp);
