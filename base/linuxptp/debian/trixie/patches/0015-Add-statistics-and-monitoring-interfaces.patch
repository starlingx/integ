+/* Monitoring socket */
+
+static const char *servo_state_str(enum servo_state s)
+{
+	switch (s) {
+	case SERVO_UNLOCKED:
+		return "UNLOCKED";
+	case SERVO_JUMP:
+		return "JUMP";
+	case SERVO_LOCKED:
+		return "LOCKED";
+	case SERVO_LOCKED_STABLE:
+		return "LOCKED_STABLE";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+static void mon_socket_handle(struct domain *domains, int n_domains)
+{
+	int client_fd;
+	char buf[MON_SCK_BUFFER_SIZE];
+	char resp[MON_SCK_BUFFER_SIZE];
+	struct clock *src = NULL;
+	struct domain *active_domain = NULL;
+	struct clock *dst = NULL;
+
+	client_fd = mon_socket_accept(domains[0].mon.fd, buf, sizeof(buf));
+	if (client_fd < 0)
+		return;
+
+	if (!strstr(buf, "\"command\"") || !strstr(buf, "\"stats\"")) {
+		snprintf(resp, sizeof(resp),
+			 "{\"error\":\"unknown command\"}");
+		mon_socket_reply(client_fd, resp);
+		return;
+	}
