+void pmc_agent_save_dds(struct pmc_agent *node, struct defaultDS *dds)
+{
+	memcpy(&node->dds, dds, sizeof(node->dds));
+	node->dds_valid = true;
+}
+
+struct defaultDS * pmc_agent_get_dds(struct pmc_agent *node)
+{
+	struct defaultDS *dds = NULL;
+	if (node->dds_valid)
+		dds = &node->dds;
+	return dds;
+}
+
+int pmc_agent_query_pds(struct pmc_agent *node, int timeout)
+{
+	struct ptp_message *msg;
+	struct parentDS *pds;
+	int res;
+
+	res = run_pmc(node, timeout, MID_PARENT_DATA_SET, &msg);
+	if (is_run_pmc_error(res)) {
+		// When there is timeout error, treat pds data as invalid
+		if (res == RUN_PMC_TMO) {
+			pr_notice("pmc agent timeout reading pmc pds");
+			node->pds_valid = false;
+		}
+		return run_pmc_err2errno(res);
+	}
+	pds = (struct parentDS *) management_tlv_data(msg);
+	memcpy(&node->pds, pds, sizeof(node->pds));
+	node->pds_valid = true;
+	msg_put(msg);
+	return 0;
+}
+
+void pmc_agent_save_pds(struct pmc_agent *node, struct parentDS *pds)
+{
+	memcpy(&node->pds, pds, sizeof(node->pds));
+	node->pds_valid = true;
+}
+
+struct parentDS * pmc_agent_get_pds(struct pmc_agent *node)
+{
+	struct parentDS *pds = NULL;
+	if (node->pds_valid)
+		pds = &node->pds;
+	return pds;
+}
+
+int pmc_agent_query_tds(struct pmc_agent *node, int timeout)
+{
+	struct ptp_message *msg;
+	struct timePropertiesDS *tds;
+	int res;
+
+	res = run_pmc(node, timeout, MID_TIME_PROPERTIES_DATA_SET, &msg);
+	if (is_run_pmc_error(res)) {
+		// When there is timeout error, treat tds data as invalid
+		if (res == RUN_PMC_TMO) {
+			pr_notice("pmc agent timeout reading pmc tds");
+			node->tds_valid = false;
+		}
+		return run_pmc_err2errno(res);
+	}
+	tds = (struct timePropertiesDS*) management_tlv_data(msg);
+	memcpy(&node->tds, tds, sizeof(node->tds));
+	node->tds_valid = true;
+	msg_put(msg);
+	return 0;
+}
+
+void pmc_agent_save_tds(struct pmc_agent *node, struct timePropertiesDS *tds)
+{
+	memcpy(&node->tds, tds, sizeof(node->tds));
+	node->tds_valid = true;
+}
+
+struct timePropertiesDS * pmc_agent_get_tds(struct pmc_agent *node)
+{
+	struct timePropertiesDS *tds = NULL;
+	if (node->tds_valid)
+		tds = &node->tds;
+	return tds;
+}
