+static bool domain_match_ha_dds_requirements(struct domain *domain)
+{
+	pr_info("domain_match_ha_dds_requirements check domain %p", domain);
+	/* sanity check */
+	if (domain->agent == NULL) {
+		pr_debug("domain pmc agent is (null)");
+		return false;
+	}
+
+	if (domain->src_clock && domain->src_clock->device) {
+		pr_info("clock %s", domain->src_clock->device);
+	}
+
+	struct defaultDS *dds = pmc_agent_get_dds(domain->agent);
+	if (dds == NULL) {
+		pr_debug("domain default data set is invalid");
+		return false;
+	}
+
+	/* max local clock class (lower is better) */
+	int local_clock_class = dds->clockQuality.clockClass;
+	int max_local_clock_class = domain->ha_limits.local.clockClass;
+	if (local_clock_class > max_local_clock_class) {
+		pr_debug("local clock class %d > max local clock class %d",
+			local_clock_class, max_local_clock_class);
+		return false;
+	}
+
+	/* max clock accuracy (lower is better) */
+	unsigned int clock_accuracy = dds->clockQuality.clockAccuracy;
+	unsigned int max_clock_accuracy = domain->ha_limits.local.clockAccuracy;
+	if (clock_accuracy > max_clock_accuracy) {
+		pr_debug("clock accuracy %d > max clock accuracy %d",
+			clock_accuracy, max_clock_accuracy);
+		return false;
+	}
+
+	/* max offset scaled log variance (lower is better) */
+	unsigned int offset = dds->clockQuality.offsetScaledLogVariance;
+	unsigned int max_offset = domain->ha_limits.local.offsetScaledLogVariance;
+	if (offset > max_offset) {
+		pr_debug("offset scaled log variance 0x%x > max offset 0x%x",
+			offset, max_offset);
+		return false;
+	}
+
+	return true;
+}
+
+static bool domain_match_ha_tds_requirements(struct domain *domain)
+{
+	pr_info("domain_match_ha_tds_requirements check domain %p", domain);
+
+	/* sanity check */
+	if (domain->agent == NULL) {
+		pr_debug("domain pmc agent is (null)");
+		return false;
+	}
+
+	if (domain->src_clock && domain->src_clock->device) {
+		pr_info("clock %s", domain->src_clock->device);
+	}
+
+	struct timePropertiesDS *tds = pmc_agent_get_tds(domain->agent);
+	if (tds == NULL) {
+		pr_debug("domain time properties data set is invalid");
+		return false;
+	}
+
+	/* is time traceable */
+	bool time_traceable = tds->flags & TIME_TRACEABLE;
+	bool check_time_traceable = domain->ha_limits.check_time_traceable;
+	if (check_time_traceable && !time_traceable) {
+		pr_debug("time is not traceable");
+		return false;
+	}
+
+	/* is frequency traceable */
+	bool freq_traceable = tds->flags & FREQ_TRACEABLE;
+	bool check_freq_traceable = domain->ha_limits.check_freq_traceable;
+	if (check_freq_traceable && !freq_traceable) {
+		pr_debug("frequency is not traceable");
+		return false;
+	}
+
+	return true;
+}
+
+static bool domain_match_ha_pds_requirements(struct domain *domain)
+{
+	pr_info("domain_match_ha_pds_requirements check domain %p", domain);
+
+	/* sanity check */
+	if (domain->agent == NULL) {
+		pr_debug("domain pmc agent is (null)");
+		return false;
+	}
+
+	if (domain->src_clock && domain->src_clock->device) {
+		pr_info("clock %s", domain->src_clock->device);
+	}
+
+	struct parentDS *pds = pmc_agent_get_pds(domain->agent);
+	if (pds == NULL) {
+		pr_debug("domain parent data set is invalid");
+		return false;
+	}
+
+	/* max gm clock class (lower is better) */
+	int gm_clock_class = pds->grandmasterClockQuality.clockClass;
+	int max_gm_clock_class = domain->ha_limits.gm.clockClass;
+	if (gm_clock_class > max_gm_clock_class) {
+		pr_debug("GM clock class %d > max clock class %d",
+			gm_clock_class, max_gm_clock_class);
+		return false;
+	}
+
+	/* max clock accuracy (lower is better) */
+	unsigned int gm_clock_accuracy = pds->grandmasterClockQuality.clockAccuracy;
+	unsigned int max_gm_clock_accuracy = domain->ha_limits.gm.clockAccuracy;
+	if (gm_clock_accuracy > max_gm_clock_accuracy) {
+		pr_debug("GM clock accuracy %d > max clock accuracy %d",
+			gm_clock_accuracy, max_gm_clock_accuracy);
+		return false;
+	}
+
+	/* max offset scaled log variance (lower is better) */
+	unsigned int offset = pds->grandmasterClockQuality.offsetScaledLogVariance;
+	unsigned int max_offset = domain->ha_limits.gm.offsetScaledLogVariance;
+	if (offset > max_offset) {
+		pr_debug("GM offset scaled log variance 0x%x > max offset 0x%x",
+			offset, max_offset);
+		return false;
+	}
+
+	return true;
+}
+
+static bool domain_match_ha_requirements(struct domain *domain)
+{
+	return domain_match_ha_dds_requirements(domain) &&
+		domain_match_ha_tds_requirements(domain) &&
+		domain_match_ha_pds_requirements(domain);
+}
+
+static int compare_domains_ha(struct domain *a, struct domain *b)
+{
+	if (!a || !b) {
+		if (a && a->src_clock)
+			return -1;
+		if (b && b->src_clock)
+			return 1;
+		return 0;
+	}
+
+	if (!a->src_clock != !b->src_clock)
+		return !!b->src_clock - !!a->src_clock;
+
+	bool a_matches = domain_match_ha_requirements(a);
+	bool b_matches = domain_match_ha_requirements(b);
+	/* only one matches, select it */
+	if (a_matches && !b_matches) {
+		pr_debug("only domain %p matches HA requirements", a);
+		return -1;
+	}
+
+	if (b_matches && !a_matches) {
+		pr_debug("only domain %p matches HA requirements", b);
+		return 1;
+	}
+
+	/* both match requirements, select the one with the highest priority */
+	if (a_matches || b_matches) {
+		pr_debug("both domains %p and %p match HA requirements", a, b);
+		pr_debug("selecting the one with higher priority: %d vs %d",
+			a->ha_priority, b->ha_priority);
+		return b->ha_priority - a->ha_priority;
+	}
+
+	/* none match requirements, select the one with the best clock class */
+	pr_debug("none of the following domains match HA requirements: %p and %p", a, b);
+	struct defaultDS *a_dds = pmc_agent_get_dds(a->agent);
+	struct defaultDS *b_dds = pmc_agent_get_dds(b->agent);
+	if (!a_dds || !b_dds) {
+		if (a_dds)
+			return -1;
+		if (b_dds)
+			return 1;
+		return 0;
+	}
+	pr_debug("selecting the one with lowest clock class: %d vs %d",
+		a_dds->clockQuality.clockClass, b_dds->clockQuality.clockClass);
+	return b_dds->clockQuality.clockClass - a_dds->clockQuality.clockClass;
+}
+
