@@ -73,6 +73,10 @@
 
 #define FORCED_SOURCE_CLOCK_PRIORITY 254
 
+#define HA_SCK_N_FD 1
+#define HA_SCK_BUFFER_SIZE 1024
+#define HA_SCK_FILEMODE (S_IRUSR|S_IWUSR|S_IRGRP|S_IWGRP) /*0660*/
+
 struct clock {
 	LIST_ENTRY(clock) list;
 	LIST_ENTRY(clock) dst_list;
@@ -111,13 +115,16 @@ struct ha_limits {
 };
 
 struct ha {
-	bool enabled;
+	bool ha_enabled;
+	bool domain_enabled;
 	bool good;
+	bool forced;
 	char *src_name;
 	int priority;
 	int stability_timer;
 	uint64_t last_update;
 	struct ha_limits limits;
+	int socked_fd;
 };
 
 struct domain {
@@ -488,6 +495,500 @@ static int reconfigure_domain(struct domain *domain)
 	return 0;
 }
 
+static int ha_com_socket_open(int *fd_out, const char *path)
+{
+	int fd, err;
+	struct sockaddr_un sa;
+	const int backlog = 50;
+
+	unlink(path);
+
+	fd = socket(AF_LOCAL, SOCK_STREAM | SOCK_NONBLOCK, 0);
+	if (fd < 0) {
+		pr_err("ha_com_socket: failed to create socket: %m");
+		return -1;
+	}
+
+	memset(&sa, 0, sizeof(sa));
+	sa.sun_family = AF_LOCAL;
+	strncpy(sa.sun_path, path, sizeof(sa.sun_path) - 1);
+
+	err = bind(fd, (struct sockaddr *) &sa, sizeof(sa));
+	if (err < 0) {
+		pr_err("ha_com_socket: bind failed: %m");
+		close(fd);
+		return -1;
+	}
+
+	err = listen(fd, backlog);
+	if (err < 0) {
+		pr_err("ha_com_socket: listen failed: %m");
+		close(fd);
+		return -1;
+	}
+
+	*fd_out = fd;
+	chmod(path, HA_SCK_FILEMODE);
+
+	return 0;
+}
+
+static int ha_com_socket_close(int fd)
+{
+	struct sockaddr_un sa;
+	socklen_t len = sizeof(sa);
+
+	if (!getsockname(fd, (struct sockaddr *) &sa, &len) &&
+		sa.sun_family == AF_LOCAL) {
+		unlink(sa.sun_path);
+	}
+
+	shutdown(fd, SHUT_RDWR);
+	close(fd);
+	return 0;
+}
+
+static int ha_com_socket_recv(int fd, void *buf, size_t buflen)
+{
+	int cnt;
+
+	cnt = read(fd, buf, buflen);
+	if (cnt <= 0) {
+		pr_err("ha_com_socket: read failed: %m");
+		return -errno;
+	}
+
+	((char*)buf)[cnt] = '\0';
+
+	return 0;
+}
+
+static int ha_com_socket_send(int fd, void *buf, size_t buflen)
+{
+	int cnt;
+
+	cnt = send(fd, buf, buflen, MSG_NOSIGNAL);
+	if (cnt < 0) {
+		pr_err("ha_com_socket: send failed: %m");
+		return -errno;
+	}
+	return cnt;
+}
+
+static bool starts_with(const char *prefix, const char *str)
+{
+	return 0 == strncmp(prefix, str, strlen(prefix) - 1);
+}
+
+static char * str_at_column(char *msg, size_t column)
+{
+	int i;
+	char * str = NULL;
+
+	/* split and walk over the columns */
+	strtok(msg, " ");
+	for (i = 1; i < column; i++) {
+		str = strtok(NULL, " ");
+	}
+
+	return str;
+}
+
+static bool domain_match_ha_requirements(struct domain *domain);
+
+static int ha_handle_status_msg(struct domain *domains, int n_domains,
+								char *response, size_t resplen)
+{
+	int i;
+	struct domain *domain;
+	struct defaultDS *dds;
+	struct parentDS *pds;
+	struct timePropertiesDS *tds;
+	bool master, disabled, better;
+	bool forced_source_clock = false;
+	size_t curlen = 0;
+
+	/* header */
+	curlen = snprintf(response, resplen,
+		"act   interface   priority   clockClass   clockAcc   offset   time   freq   "
+		"gm.clockClass    gm.clockAcc   gm.offset\n\n");
+
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+		
+		/* sanity check */
+		if (domain->agent == NULL)
+			continue;
+		if (domain->src_clock == NULL)
+			continue;
+
+		master = domain->src_domain == domain;
+		disabled = !domain->ha.domain_enabled;
+		better = domain_match_ha_requirements(domain) &&
+				 (domain->ha.priority > domain->src_domain->ha.priority);
+
+		dds = pmc_agent_get_dds(domain->agent);
+		if (dds == NULL)
+			continue;
+
+		pds = pmc_agent_get_pds(domain->agent);
+		if (pds == NULL)
+			continue;
+
+		tds = pmc_agent_get_tds(domain->agent);
+		if (tds == NULL)
+			continue;
+
+		curlen += snprintf(response + curlen,
+			resplen - curlen,
+			" %c    %9s   %8d   %10d       0x%2x   0x%4x     %s    %s  %13d   "
+			"        0x%2x      0x%4x\n",
+			master ?
+				'*' :
+				better ?
+					'-' :
+					disabled ?
+						'x' :
+						' ',
+			domain->ha.src_name,
+			domain->ha.priority,
+			dds->clockQuality.clockClass,
+			dds->clockQuality.clockAccuracy,
+			dds->clockQuality.offsetScaledLogVariance,
+			tds->flags & TIME_TRACEABLE ? "yes" : "no ",
+			tds->flags & FREQ_TRACEABLE ? "yes" : "no ",
+			pds->grandmasterClockQuality.clockClass,
+			pds->grandmasterClockQuality.clockAccuracy,
+			pds->grandmasterClockQuality.offsetScaledLogVariance
+		);
+
+		if ((domain->ha.priority == FORCED_SOURCE_CLOCK_PRIORITY) ||
+			domain->ha.forced) {
+			
+			forced_source_clock = true;
+		}
+	}
+
+	curlen += snprintf(response + curlen,
+		resplen - curlen,
+		"\n\n"
+		"Source forced? %s\n",
+		forced_source_clock ? "yes" : "no"
+	);
+
+	return curlen;
+}
+
+static int ha_handle_is_forced(struct domain *domains, int n_domains,
+							   char *response, size_t resplen)
+{
+	int i;
+	struct domain *domain;
+	bool forced_source_clock = false;
+
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+
+		if ((domain->ha.priority == FORCED_SOURCE_CLOCK_PRIORITY) ||
+			domain->ha.forced) {
+				
+			forced_source_clock = true;
+		}
+	}
+
+	return snprintf(response, resplen, "%s",
+					forced_source_clock ? "True" : "False");
+}
+
+static void ha_set_clock_source(struct domain *domains, int n_domains,
+								struct domain *src_domain)
+{
+	int i;
+	struct domain *domain;
+
+	pr_notice("new clock source selected %s", src_domain->ha.src_name);
+
+	src_domain->ha.forced = true;
+
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+		domain->src_clock = src_domain->src_clock;
+		domain->src_domain = src_domain;
+		domain->ha.stability_timer = 0;
+	}
+}
+
+static int ha_handle_enable_lock_msg(struct domain *domains, int n_domains,
+									 char *request, char* response, size_t resplen)
+{
+	int i;
+	struct domain *domain, *src_domain = NULL;
+	char *src_name = NULL;
+
+	/* This command expected is 'enable lock <interface>',
+	 * then the 3rd argument is the source interface name.
+	 */
+	src_name = str_at_column(request, 3);
+	if (strlen(src_name) == 0) {
+		return snprintf(response, resplen,
+						"Error: Usage 'enable lock <interface>'");
+	}
+
+	/* search for the domain with the interface name */
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+
+		if (domain->ha.src_name == src_name) {
+			src_domain = domain;
+			break;
+		}
+			
+	}
+
+	/* check the search result */
+	if (src_domain == NULL) {
+		return snprintf(response, resplen, "Error: Interface not found");
+	}
+
+	pr_info("HA automatic source selection is disabled by command");
+	pr_info("Only interface %s will be used as source clock",
+		src_domain->ha.src_name);
+
+	ha_set_clock_source(domains, n_domains, src_domain);
+
+	return snprintf(response, resplen, "Success");
+}
+
+static int ha_handle_disable_lock_msg(struct domain *domains, int n_domains,
+									  char* response, size_t resplen)
+{
+	int i;
+	struct domain *domain;
+
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+		domain->ha.forced = false;
+		/* trigger best available clock selection algorithm */
+		domain->state_changed = true;
+	}
+
+	return snprintf(response, resplen, "Success");
+}
+
+static int ha_handle_enable_source_msg(struct domain *domains, int n_domains,
+									   char *request, char* response, size_t resplen)
+{
+	int i;
+	struct domain *domain, *enable_domain = NULL;
+	char *src_name = NULL;
+
+	/* This command expected is 'enable source <interface>',
+	 * then the 3rd argument is the source interface name.
+	 */
+	src_name = str_at_column(request, 3);
+	if (strlen(src_name) == 0) {
+		return snprintf(response, resplen,
+						"Error: Usage 'enable source <interface>'");
+	}
+
+	/* search for the domain with the interface name */
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+
+		if (domain->ha.src_name == src_name) {
+			enable_domain = domain;
+			break;
+		}
+			
+	}
+
+	/* check the search result */
+	if (enable_domain == NULL) {
+		return snprintf(response, resplen, "Error: Interface not found");
+	}
+
+	enable_domain->ha.domain_enabled = true;
+	/* trigger best available clock selection algorithm */
+	enable_domain->state_changed = true;
+
+	return snprintf(response, resplen, "Success");
+}
+
+static int ha_handle_disable_source_msg(struct domain *domains, int n_domains,
+									   char *request, char* response, size_t resplen)
+{
+	int i;
+	struct domain *domain, *disable_domain = NULL;
+	char *src_name = NULL;
+	size_t counter = 0;
+
+	/* This command expected is 'disable source <interface>',
+	 * then the 3rd argument is the source interface name.
+	 */
+	src_name = str_at_column(request, 3);
+	if (strlen(src_name) == 0) {
+		return snprintf(response, resplen,
+						"Error: Usage 'disable source <interface>'");
+	}
+
+	/* Search for the domain with the interface name and
+	 * count the number of domains enabled
+	 */
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+
+		if (domain->ha.domain_enabled)
+			counter++;
+
+		if (domain->ha.src_name == src_name) {
+			disable_domain = domain;
+		}
+	}
+
+	/* Check the search result */
+	if (disable_domain == NULL) {
+		return snprintf(response, resplen,
+						"Error: Interface not found");
+	}
+
+	/* Check if domain is enabled, if already disabled
+	 * return success
+	 */
+	if (!disable_domain->ha.domain_enabled) {
+		return snprintf(response, resplen, "Success");
+	}
+
+	/* Check if it is the last domain enabled */
+	if (counter <= 1) {
+		return snprintf(response, resplen, "Error: Last interface enabled");
+	}
+
+	disable_domain->ha.domain_enabled = false;
+	/* trigger best available clock selection algorithm */
+	disable_domain->state_changed = true;
+
+	return snprintf(response, resplen, "Success");
+}
+
+static int ha_handle_valid_sources_msg(struct domain *domains, int n_domains,
+									   char* response, size_t resplen)
+{
+	int i;
+	struct domain *domain;
+	size_t curlen = 0;
+
+	/* List the source interface name of the domains that are matching
+	 * the HA requirements.
+	 */
+	for (i = 0; i < n_domains; i++) {
+		domain = &domains[i];
+		if (domain_match_ha_requirements(domain)) {
+			curlen += snprintf(response + curlen,
+							   resplen - curlen,
+							   "%s ",
+							   domain->ha.src_name);
+		}
+	}
+
+	/* If no domain matches the requirements, return None*/
+	if (curlen == 0) {
+		curlen = snprintf(response, resplen, "None");
+	}
+
+	return curlen;
+}
+
+static int ha_com_socket_handle_msg(struct domain *domains, int n_domains)
+{
+	int fd, res, cnt;
+	void *buffer = NULL;
+	void *response = NULL;
+
+	while(true) {
+		fd = accept(domains[0].ha.socked_fd, NULL, NULL);
+		if (fd < 0) {
+			if (errno == EAGAIN || errno == EWOULDBLOCK) {
+				/* no msg available*/
+			} else {
+				pr_err("ha_com_socket: accept failed: %m");
+				res = -1;
+			}
+			break;
+		}
+
+		buffer = malloc(HA_SCK_BUFFER_SIZE);
+		if (!buffer) {
+			pr_err("ha_com_socket: failed to allocate memory for message");
+			close(fd);
+			res = -1;
+			break;
+		}
+
+		res = ha_com_socket_recv(fd, buffer, HA_SCK_BUFFER_SIZE);
+		if (res < 0) {
+			close(fd);
+			break;
+		}
+
+		pr_debug("ha_com_socket: command received: %s", (char*)buffer);
+
+		response = malloc(HA_SCK_BUFFER_SIZE);
+		if (!response) {
+			pr_err("ha_com_socket: failed to allocate memory for response message");
+			close(fd);
+			res = -1;
+			break;
+		}
+
+		/* handle messages and create responses */
+		if (strcmp((const char*)buffer, "status") == 0) {
+			cnt = ha_handle_status_msg(domains, n_domains, response,
+									   HA_SCK_BUFFER_SIZE);
+		} else if (strcmp((const char*)buffer, "clock source") == 0) {
+			if (domains[0].src_domain) {
+				cnt = snprintf((char*)response,
+							   HA_SCK_BUFFER_SIZE,
+							   "%s",
+							   domains[0].src_domain->ha.src_name);
+			} else {
+				cnt = snprintf((char*)buffer, HA_SCK_BUFFER_SIZE, "None");
+			}
+		} else if (strcmp((const char*)buffer, "forced lock") == 0) {
+			cnt = ha_handle_is_forced(domains, n_domains, response,
+									  HA_SCK_BUFFER_SIZE);
+		} else if (starts_with("enable lock", buffer)) {
+			cnt = ha_handle_enable_lock_msg(domains, n_domains, buffer,
+											response, HA_SCK_BUFFER_SIZE);
+		} else if (strcmp((const char*)buffer, "disable lock") == 0) {
+			cnt = ha_handle_disable_lock_msg(domains, n_domains, response,
+											 HA_SCK_BUFFER_SIZE);
+		} else if (starts_with("enable source", buffer)) {
+			cnt = ha_handle_enable_source_msg(domains, n_domains, buffer,
+											  response, HA_SCK_BUFFER_SIZE);
+		} else if (starts_with("disable source", buffer)) {
+			cnt = ha_handle_disable_source_msg(domains, n_domains, buffer,
+											   response, HA_SCK_BUFFER_SIZE);
+		} else if (strcmp((const char*)buffer, "valid sources") == 0) {
+			cnt = ha_handle_valid_sources_msg(domains, n_domains, response,
+											  HA_SCK_BUFFER_SIZE);
+		} else {
+			cnt = snprintf((char*)response, HA_SCK_BUFFER_SIZE,
+						   "Error: Invalid command");
+		}
+
+		pr_debug("ha_com_socket: response: %s", (char*)response);
+
+		res = ha_com_socket_send(fd, response, cnt);
+
+		close(fd);
+	}
+
+	free(buffer);
+	free(response);
+
+	return res;
+}
+
 static bool domain_match_ha_dds_requirements(struct domain *domain)
 {
 	pr_info("domain_match_ha_dds_requirements check domain %s",
@@ -643,17 +1144,31 @@ static int compare_domains_ha(struct domain *a, struct domain *b)
