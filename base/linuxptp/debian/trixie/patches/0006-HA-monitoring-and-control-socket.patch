 			    (domain->ha.last_update + domain->ha.stability_timer * NS_PER_SEC < now)) {
 
@@ -1228,7 +1745,7 @@ static int phc2sys_recv_subscribed(void *context, struct ptp_message *msg,
 		if (old_parent_ds == NULL || compare_parent_data_set(parent_ds, old_parent_ds)) {
 			pr_info("domain %p %s parent data set changed",
 				domain,
-				domain->ha.enabled ? domain->ha.src_name : "");
+				domain->ha.ha_enabled ? domain->ha.src_name : "");
 			domain->state_changed = 1;
 			domain->ha.last_update = ts;
