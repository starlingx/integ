diff --git a/sbin/ldapsetupfullname b/sbin/ldapsetupfullname
new file mode 100755
index 0000000..a6f1bba
--- /dev/null
+++ b/sbin/ldapsetupfullname
@@ -0,0 +1,78 @@
+#!/bin/bash
+
+# ldapsetufullname - Update full name for an existing LDAP user
+
+#  Copyright (c) 2026 Wind River Systems, Inc.
+#
+#  This program is free software; you can redistribute it and/or
+#  modify it under the terms of the GNU General Public License
+#  as published by the Free Software Foundation; either version 2
+#  of the License, or (at your option) any later version.
+#
+#  This program is distributed in the hope that it will be useful,
+#  but WITHOUT ANY WARRANTY; without even the implied warranty of
+#  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+#  GNU General Public License for more details.
+#
+#  You should have received a copy of the GNU General Public License
+#  along with this program; if not, write to the Free Software
+#  Foundation, Inc., 59 Temple Place - Suite 330, Boston, MA 02111-1307,
+#  USA.
+
+if [ $# -ne 2 ]
+then
+  echo "Usage: $0 <username> <full name>"
+  exit 1
+fi
+
+# Source runtime file
+_RUNTIMEFILE="/usr/lib/ldapscripts/runtime"
+. "$_RUNTIMEFILE"
+
+_USER="$1"
+_FULLNAME="$2"
+
+# Validate username: only allow safe characters to prevent LDIF injection
+if ! [[ "$_USER" =~ ^[a-zA-Z0-9._-]+$ ]]
+then
+  end_die "Invalid username: $_USER (only alphanumeric, dot, underscore, and hyphen allowed)"
+fi
+
+# Sanitize input for LDAP filter to prevent LDAP injection
+_SAFE_USER=$(printf '%s' "$_USER" | sed 's/\\/\\5c/g; s/\*/\\2a/g; s/(/\\28/g; s/)/\\29/g; s/\x00/\\00/g')
+
+# Find username : $1 must exist in LDAP !
+_findentry "$USUFFIX,$SUFFIX" "(&(objectClass=posixAccount)(|(uid=$_SAFE_USER)(uidNumber=$_SAFE_USER)))"
+[ -z "$_ENTRY" ] && end_die "User $_USER not found in LDAP"
+
+# Use the DN returned by _findentry instead of reconstructing it
+USERDN="$_ENTRY"
+
+# Temporary LDIF file
+mktempf
+
+cat <<EOF > "$_TMPFILE"
+dn: ${USERDN}
+changetype: modify
+replace: cn
+cn: ${_FULLNAME}
+-
+replace: gecos
+gecos: ${_FULLNAME}
+EOF
+
+if [ $? -ne 0 ]
+then
+  end_die "Error writing to temporary file $_TMPFILE"
+fi
+
+echo "Updating full name for user: ${_USER}"
+
+cat "$_TMPFILE" | _utf8encode | _ldapmodify
+
+if [ $? -ne 0 ]
+then
+  end_die "Error updating user full name in LDAP"
+fi
+
+end_ok
diff --git a/sbin/ldapusersetup b/sbin/ldapusersetup
old mode 100644
new mode 100755
index 4534a26..684dbcc
--- a/sbin/ldapusersetup
+++ b/sbin/ldapusersetup
@@ -27,7 +27,9 @@ where accepted field(s) are as follows:
 --secondgroup <grp>           : the secondary group to add this user to
 --passmax     <value>         : the shadowMax value for this user
 --passwarning <value>         : the shadowWarning value for this user
---email <value>               : the email value for this user"
+--email       <value>         : the email value for this user
+--fullname    <value>         : the full name value for this user, if it
+                                contains spaces, enclose it in double quotes."
   exit 1
 fi
 
@@ -151,6 +153,16 @@ LdapSetupEmail() {
   [ $? -eq 0 ] || end_die "Critical setup error: cannot add email to $1"
 }
 
+# Update full name for user
+# Input : username ($1), full name ($2)
+# Output : none
+LdapSetupFullName() {
+  _fullname="$2"
+  [ -z "$2" ] && _fullname="$1"
+  ldapsetupfullname "$1" "$_fullname"
+  [ $? -eq 0 ] || end_die "Critical setup error: cannot add full name to $1"
+}
+
 # Since this setup script is meant to be a
 # wrapper on top of existing ldap scripts,
 # it share invoke those... we could have achieved
@@ -158,7 +170,8 @@ LdapSetupEmail() {
 # at the expense of massively redundant code
 # duplication.
 declare -a helper_scripts=("ldapadduser" "ldapaddsudo" "ldapmodifyuser" \
-                           "ldapaddusertogroup" "ldapsetupemail" "$_BASHSHELL")
+                           "ldapaddusertogroup" "ldapsetupemail" \
+                           "ldapsetupfullname" "$_BASHSHELL")
 
 # Do some quick sanity tests to make sure
 # helper scripts are present
@@ -175,6 +188,10 @@ if [ "$#" -eq 0 ]; then
   read _username
   LdapAddUser "$_username"
 
+  echo -e "Enter user's full name to add to LDAP:[$_username]: "
+  read _fullname
+  LdapSetupFullName "$_username" "$_fullname"
+
   # Replace the login shell. Only bash is supported now.
   LdapAddLoginShell "$_username"
 
@@ -226,6 +243,10 @@ else
 	_username="$2"
 	shift
 	;;
+       -f|--fullname) # optional
+       _fullname="$2"
+	shift
+	;;
 	--sudo)      # optional
 	_sudo="yes"
 	;;
@@ -257,6 +278,9 @@ else
   [ -z "$_username" ] && end_die "No username argument specified"
   LdapAddUser $_username
 
+  # Change user full name
+  LdapSetupFullName $_username "$_fullname"
+
   # Change Login Shell
   LdapAddLoginShell $_username "$_loginshell"
 
