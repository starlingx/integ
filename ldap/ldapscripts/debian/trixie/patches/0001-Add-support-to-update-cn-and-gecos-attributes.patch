From 35b9913631b4f2e1a373f87b5aa836481de54ef5 Mon Sep 17 00:00:00 2001
From: Leonardo Mendes <Leonardo.MendesSantana@windriver.com>
Date: Wed, 1 Jul 2026 10:23:21 -0300
Subject: [PATCH] Add support to update cn and gecos attributes

Add support for updating the cn and gecos attributes when creating
local ldap users, allowing users to customize the full name.

Signed-off-by: Leonardo Mendes <Leonardo.MendesSantana@windriver.com>
---
 Makefile                     |  5 ++-
 man/man1/ldapsetupfullname.1 | 45 +++++++++++++++++++++
 sbin/ldapsetupfullname       | 78 ++++++++++++++++++++++++++++++++++++
 sbin/ldapusersetup           | 28 ++++++++++++-
 4 files changed, 152 insertions(+), 4 deletions(-)
 create mode 100644 man/man1/ldapsetupfullname.1
 create mode 100755 sbin/ldapsetupfullname
 mode change 100644 => 100755 sbin/ldapusersetup

diff --git a/Makefile b/Makefile
index 93778ec..0806de4 100644
--- a/Makefile
+++ b/Makefile
@@ -41,13 +41,14 @@ SBINFILES =	ldapdeletemachine ldapmodifygroup ldapsetpasswd lsldap ldapadduser l
 			ldapdeleteuser ldapsetprimarygroup ldapfinger ldapid ldapgid ldapmodifymachine \
 			ldaprenamegroup ldapaddgroup ldapaddusertogroup ldapdeleteuserfromgroup \
 			ldapinit ldapmodifyuser ldaprenamemachine ldapaddmachine ldapdeletegroup \
-			ldaprenameuser ldapmodifysudo ldapdeletesudo ldapusersetup ldapsetupemail
+			ldaprenameuser ldapmodifysudo ldapdeletesudo ldapusersetup ldapsetupemail \
+			ldapsetupfullname
 MAN1FILES =	ldapdeletemachine.1 ldapmodifymachine.1 ldaprenamemachine.1 ldapadduser.1 \
 			ldapdeleteuserfromgroup.1 ldapfinger.1 ldapid.1 ldapgid.1 ldapmodifyuser.1 lsldap.1 \
 			ldapaddusertogroup.1 ldaprenameuser.1 ldapinit.1 ldapsetpasswd.1 ldapaddgroup.1 \
 			ldapdeletegroup.1 ldapsetprimarygroup.1 ldapmodifygroup.1 ldaprenamegroup.1 \
 			ldapaddmachine.1 ldapdeleteuser.1 ldapaddsudo.1 ldapmodifysudo.1 \
-			ldapdeletesudo.1 ldapusersetup.1 ldapsetupemail.1
+			ldapdeletesudo.1 ldapusersetup.1 ldapsetupemail.1 ldapsetupfullname.1
 MAN5FILES = ldapscripts.5
 TMPLFILES = ldapaddgroup.template.sample ldapaddmachine.template.sample \
 			ldapadduser.template.sample
