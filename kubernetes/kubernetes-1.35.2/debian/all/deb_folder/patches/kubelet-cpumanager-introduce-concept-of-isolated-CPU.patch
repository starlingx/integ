+// get the system-level isolated CPUs
+func getIsolcpus(logger logr.Logger) cpuset.CPUSet {
+	dat, err := os.ReadFile("/sys/devices/system/cpu/isolated")
+	if err != nil {
+		logger.Error(err, "[cpumanager] unable to read sysfs isolcpus subdir")
+		return cpuset.New()
+	}
+
+	// The isolated cpus string ends in a newline
+	cpustring := strings.TrimSuffix(string(dat), "\n")
+	cset, err := cpuset.Parse(cpustring)
+	if err != nil {
+		logger.Error(err, "[cpumanager] unable to parse sysfs isolcpus string to cpuset")
+		return cpuset.New()
+	}
+
+	return cset
+}
