#!/usr/bin/make -f

DEBIAN_DESTDIR := $(CURDIR)/debian/tmp
INSTALL_DIR := $(DEBIAN_DESTDIR)/opt/stx-ansible-compat/26.03
PYTHON := $(CURDIR)/bin/python3.9
DOWNLOADS := $(CURDIR)

%:
	dh $@

override_dh_auto_build:
	$(PYTHON) -m pip install --no-index --find-links=$(DOWNLOADS) \
		ansible==2.10.7 \
		ansible-base==2.10.7 \
		"jinja2>=2.11,<3.0" \
		netaddr==1.3.0 \
		jmespath==1.1.0 \
		pexpect==4.9.0
	# Replace the vendored six (1.13.0) in ansible module_utils with a modern
	# version that supports Python 3.12+. This is needed because delegate_to:
	# localhost tasks execute modules with the system Python (3.13 on Trixie).
	$(PYTHON) -m pip install --no-index --find-links=$(DOWNLOADS) --target=$(CURDIR)/_six_tmp six==1.17.0
	cp $(CURDIR)/_six_tmp/six.py $(CURDIR)/lib/python3.9/site-packages/ansible/module_utils/six/__init__.py
	rm -rf $(CURDIR)/_six_tmp

override_dh_auto_install:
	install -d -m 755 $(INSTALL_DIR)
	cp -a bin lib include share $(INSTALL_DIR)/
	sed -i '1s|.*|#!/opt/stx-ansible-compat/26.03/bin/python3.9|' $(INSTALL_DIR)/bin/ansible*

override_dh_shlibdeps:
	true

override_dh_strip:
	true

override_dh_dwz:
	true
