diff --git a/archcommon.c b/archcommon.c
index b23514e..fa4143b 100644
--- a/archcommon.c
+++ b/archcommon.c
@@ -371,4 +371,129 @@ bool iface_has_address(interface_defn *ifd) {
 	free(ifname_real);
 
 	return found;
-}
\ No newline at end of file
+}
+
+
+/*
+ * Check if the address on the interface is ready to be used as route src.
+ * just used for default routes, so if ifd does not have a gateway, return false
+ * For IPv6: returns false if dadfailed/tentative.
+ * For IPv4: returns true if the address exists on the interface.
+ */
+bool iface_address_ready_for_src(interface_defn *ifd) {
+
+	if (!ifd || !ifd->logical_iface) {
+		return false;
+	}
+
+	// mock for test cases
+	if (force_src_ready)
+		return true;
+
+	char *address = get_var("address", strlen("address"), ifd);
+
+	if (!address)
+		return false;
+
+	char *gateway = get_var("gateway", strlen("gateway"), ifd);
+	if (!gateway || strlen(gateway) == 0) {
+		free(address);
+		free(gateway);
+		return false;
+	}
+	free(gateway);
+
+	char *ifname_real = strdup(ifd->logical_iface);
+	if (!ifname_real) {
+		free(address);
+		return false;
+	}
+
+	char *sep = strchr(ifname_real, ':');
+	if (sep)
+		*sep = '\0';
+
+	bool is_ipv6 = (strchr(address, ':') != NULL);
+
+	if (!is_ipv6) {
+		// IPv4 just check if Address exists
+		bool found = iface_has_address(ifd);
+		free(address);
+		free(ifname_real);
+		return found;
+	}
+
+	// IPv6: check DAD/tentative state reading the flags from if_inet6
+	FILE *f = fopen("/proc/net/if_inet6", "r");
+	if (!f) {
+		free(address);
+		free(ifname_real);
+		return false;
+	}
+
+	char line[256];
+	bool found = false;
+	bool tentative = false;
+	bool dadfailed = false;
+
+	// /proc/net/if_inet6 format:
+	// <hex_addr> <ifindex> <prefix_len> <scope> <flags> <ifname>
+	// flags: IFA_F_TENTATIVE=0x40, IFA_F_DADFAILED=0x08
+
+	// read each IPv6 from if_inet6
+	while (fgets(line, sizeof(line), f)) {
+		char hex_addr[33], ifname[IFNAMSIZ];
+		int ifindex, prefix_len, scope, flags;
+
+		if (sscanf(line, "%32s %x %x %x %x %s",
+			   hex_addr, &ifindex, &prefix_len,
+			   &scope, &flags, ifname) != 6)
+			continue;
+
+		if (strcmp(ifname, ifname_real) != 0)
+			continue;
+
+		// Convert hex address to standard IPv6 notation
+		struct in6_addr addr6;
+		for (int i = 0; i < 16; i++) {
+			unsigned int byte;
+			sscanf(hex_addr + i * 2, "%2x", &byte);
+			addr6.s6_addr[i] = (unsigned char)byte;
+		}
+
+		char buf[INET6_ADDRSTRLEN];
+		// check if the address read in the file is the address
+		// we are looking for
+		if (!inet_ntop(AF_INET6, &addr6, buf, sizeof(buf)))
+			continue;
+
+		if (strcmp(buf, address) != 0)
+			continue;
+
+		// read the flags for this address to compare
+		found = true;
+		tentative = (flags & 0x40) != 0;
+		dadfailed = (flags & 0x08) != 0;
+
+		break;
+	}
+
+	fclose(f);
+
+	if (!found) {
+		free(address);
+		free(ifname_real);
+		return false;
+	}
+
+	// test dadfailed or tentative
+	if (dadfailed || tentative) {
+		free(address);
+		free(ifname_real);
+		return false;
+	}
+
+	free(address);
+	free(ifname_real);
+	return true;
+}
