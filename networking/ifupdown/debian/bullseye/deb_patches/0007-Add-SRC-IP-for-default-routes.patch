 	[[peer %pointopoint%]] [[scope %scope%]] dev %iface% label %iface% ; \
     if (!address_exists())
-    /sbin/ip link set dev %iface% [[mtu %mtu%]] [[address %hwaddress%]] up ;
-    [[ /sbin/ip route replace default via %gateway% [[metric %metric%]] dev %iface% onlink ]]
