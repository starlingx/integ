From c3b65c5c3b02b7483a6cbd1188e24bdb3ff721fd Mon Sep 17 00:00:00 2001
From: amantri <ayyappa.mantri@windriver.com>
Date: Fri, 6 Mar 2026 10:19:06 -0500
Subject: [PATCH] This patch replaces hardcoded passwords with LUKS filesystem

---
 keyrings/alt/file.py      | 44 ++++++++++++++++++++++++++-------------
 keyrings/alt/file_base.py |  2 +-
 2 files changed, 31 insertions(+), 15 deletions(-)

diff --git a/keyrings/alt/file.py b/keyrings/alt/file.py
index 8d0bfed..405b292 100644
--- a/keyrings/alt/file.py
+++ b/keyrings/alt/file.py
@@ -61,18 +61,36 @@ class Encrypted:
         pw = self.KDF.PBKDF2(password, salt, dkLen=self.block_size)
         return self.AES.new(pw[: self.block_size], self.AES.MODE_CFB, IV)

+    def _get_luks_keyring_secret_path(self):
+        """Get the path to the keyring secret file on LUKS filesystem."""
+        # Default: read from LUKS filesystem based on SW_VERSION
+        try:
+            with open('/etc/build.info', 'r') as f:
+                for line in f:
+                    if line.startswith('SW_VERSION='):
+                        sw_version = line.split('=')[1].strip().strip('"')
+                        return f"/var/luks/stx/luks_fs/controller/.keyring/{sw_version}/python_keyring/.keyring_secret"
+        except Exception as e:
+            sys.stderr.write(f"Unexpected error parsing build info: {e}\n")
+
     def _get_new_password(self):
-        while True:
-            password = getpass.getpass("Please set a password for your new keyring: ")
-            confirm = getpass.getpass('Please confirm the password: ')
-            if password != confirm:  # pragma: no cover
-                sys.stderr.write("Error: Your passwords didn't match\n")
-                continue
-            if '' == password.strip():  # pragma: no cover
-                # forbid the blank password
-                sys.stderr.write("Error: blank passwords aren't allowed.\n")
-                continue
-            return password
+        """Get keyring password from environment variable or LUKS secret file."""
+        # Check for environment variable password first
+        env_password = os.environ.get('KEYRING_PASSWORD')
+        if env_password:
+            return env_password
+
+        # Read from LUKS secret file
+        keyring_secret_file = self._get_luks_keyring_secret_path()
+        if keyring_secret_file and os.path.exists(keyring_secret_file):
+            try:
+                with open(keyring_secret_file, 'r') as f:
+                    return f.read().strip()
+            except Exception as e:
+                sys.stderr.write(f"Failed to read LUKS keyring secret: {e}\n")
+                raise
+        else:
+            raise FileNotFoundError("LUKS keyring secret file not available")


 class EncryptedKeyring(Encrypted, Keyring):
@@ -179,9 +197,7 @@ class EncryptedKeyring(Encrypted, Keyring):
         Unlock this keyring by getting the password for the keyring from the
         user.
         """
-        self.keyring_key = getpass.getpass(
-            'Please enter password for encrypted keyring: '
-        )
+        self.keyring_key = self._get_new_password()
         try:
             ref_pw = self.get_password('keyring-setting', 'password reference')
             assert ref_pw == 'password reference value'
diff --git a/keyrings/alt/file_base.py b/keyrings/alt/file_base.py
index aa70a49..d157f38 100644
--- a/keyrings/alt/file_base.py
+++ b/keyrings/alt/file_base.py
@@ -163,7 +163,7 @@ class Keyring(FileBacked, KeyringBackend):
             # create the file without group/world permissions
             with open(self.file_path, 'w', encoding='utf-8'):
                 pass
-            user_read_write = 0o600
+            user_read_write = 0o640
             os.chmod(self.file_path, user_read_write)

     def delete_password(self, service, username):
--
2.34.1
